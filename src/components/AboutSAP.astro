---
const { t } = Astro.props
---

<section>

<div class="container">

<h2>{t.aboutTitle}</h2>

<div class="grid">

<div class="card">
<h3>{t.block1Title}</h3>
<p>{t.block1Text}</p>
</div>

<div class="card">
<h3>{t.block2Title}</h3>
<p>{t.block2Text}</p>
</div>

<div class="card">
<h3>{t.block3Title}</h3>
<p>{t.block3Text}</p>
</div>

</div>

</div>

</section>

<style>

section{
padding:80px 0;
}

h2{
text-align:center;
margin-bottom:40px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:30px;
}

.card{
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 10px 20px rgba(0,0,0,0.05);
}

</style>