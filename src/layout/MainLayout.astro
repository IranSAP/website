---
const { title } = Astro.props;
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />

<title>{title}</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
body{
  margin:0;
  font-family:Inter, system-ui;
  background:#F8FAFC;
  color:#0F172A;
}

.container{
  max-width:1100px;
  margin:0 auto;
  padding:0 32px;
}

h1,h2,h3{
  margin:0;
}

section{
  padding:100px 0;
}

section h2{
  text-align:center;
  font-size:36px;
}

.primary{
  background:#0A6ED1;
  color:white;
  padding:14px 28px;
  border-radius:8px;
  text-decoration:none;
}

.secondary{
  border:1px solid #0A6ED1;
  padding:14px 28px;
  border-radius:8px;
  text-decoration:none;
}
</style>

</head>

<body>

<slot />

</body>
</html>